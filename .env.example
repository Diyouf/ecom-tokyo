# Environment Variables for TOKYO Sports Shop

# Admin Panel Password (CHANGE THIS BEFORE DEPLOYING!)
ADMIN_PASSWORD=admin123

# WhatsApp Number (include country code, no + sign or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=1234567890

# Shop Name
NEXT_PUBLIC_SHOP_NAME="Rival in Retro"

# Vercel Blob (Required for image uploads in production)
# Get this from your Vercel dashboard → Storage → Blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Session Secret (for signing admin cookies)
SESSION_SECRET=change-this-to-a-random-secret-string-32chars
